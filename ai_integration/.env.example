# SmartHealth AI Integration Configuration
# Copy this file to .env and fill in your actual values

# OpenRouter API Configuration
# Get your API key from https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model selection
# Available models:
# - nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free (recommended - free reasoning model)
# - openchat/openchat-7b
# - meta-llama/llama-2-7b-chat
# - mistralai/mistral-7b-instruct
# - others available on OpenRouter
OPENROUTER_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# Site Information for OpenRouter (optional but recommended)
SITE_URL=http://localhost:3000
SITE_NAME=SmartHealth AI

# Request Configuration
REQUEST_TIMEOUT=30           # Timeout in seconds
TEMPERATURE=0.7             # Creativity level (0.0-1.0, lower = more deterministic)
MAX_TOKENS=1000            # Maximum response length

# Logging Configuration
LOG_LEVEL=INFO              # DEBUG, INFO, WARNING, ERROR
LOG_FILE=logs/ai_service.log

# Database Configuration
# Default: ai_queue.db
DB_PATH=ai_queue.db

# Optional: API Rate Limiting
API_RATE_LIMIT=100          # Requests per minute
